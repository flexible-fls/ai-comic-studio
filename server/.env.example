# AI漫剧工坊 - 环境变量配置
# 复制此文件为 .env 并填入你的API密钥

# 服务器配置
PORT=3001
NODE_ENV=development

# JWT密钥 (修改为安全的随机字符串)
JWT_SECRET=your-super-secret-jwt-key-change-this

# ========== AI API 配置 ==========

# Hugging Face (免费方案)
# 1. 注册 https://huggingface.co
# 2. 创建 Token: https://huggingface.co/settings/tokens
# 3. 免费模型: stabilityai/stable-diffusion-2-1
HF_TOKEN=

# OpenAI (可选，付费方案)
# 获取API Key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Stability AI (可选)
# 获取API Key: https://platform.stability.ai
STABILITY_API_KEY=

# Runway (视频生成，可选)
# 获取API Key: https://runwayml.com/developer
RUNWAY_API_KEY=

# Pika Labs (视频生成，可选)
PIKA_API_KEY=

# ========== LiblibAI 配置 ==========
# 注册: https://www.liblib.ai
# API开放平台: https://www.liblib.ai/api (或 cloud.liblib.ai)
LIBLIB_ACCESS_KEY=
LIBLIB_SECRET_KEY=
# 模型选择: star3 (星流) 或 liblib (自定义模型)
LIBLIB_DEFAULT_MODEL=liblib
